// Prisma schema for ERP core with specialized Milling Plant inventory & traceability.
// Full HACCP/ISO 22000 compliant traceability from farm gate to retail shelf
// Datasource: MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  QC_INSPECTOR
  WAREHOUSE_OPERATOR
}

enum ItemType {
  RAW_MATERIAL
  FINISHED_GOOD
  BY_PRODUCT
}

enum UnitOfMeasure {
  KG
  BAG
  TONNE
}

enum QCStatus {
  QUARANTINED
  APPROVED
  REJECTED
}

enum BatchStatus {
  QUARANTINED
  APPROVED
  REJECTED
  IN_PRODUCTION
  CONSUMED
}

enum DispatchStatus {
  PENDING
  LOADED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      UserRole  @default(EMPLOYEE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  invoices  Invoice[] @relation("InvoiceCreatedBy")
}

model InventoryItem {
  id          String        @id @default(cuid())
  sku         String        @unique
  name        String
  description String? 
  type        ItemType      @default(FINISHED_GOOD)
  unit        UnitOfMeasure @default(KG)
  quantity    Decimal       @default(0.00) @db.Decimal(12, 3) // precisely track fractional weights
  unitPrice   Decimal       @default(0.00) @db.Decimal(10, 2) // base unit price

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  priceBook   PriceBook[]
}

model PriceBook {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  priceType   String        // e.g. RETAIL, WHOLESALE, DISTRIBUTOR
  price       Decimal       @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([itemId, priceType])
}

// ============================================
// TRACEABILITY MODULE - SUPPLIERS & RAW MATERIALS
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  code            String    @unique // e.g. SUP-001
  name            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?   @db.Text
  farmLocation    String?   // GPS coordinates or farm name
  certifications  String?   @db.Text // e.g. "Organic, GlobalGAP"
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  rawMaizeBatches RawMaizeBatch[]

  @@index([code])
  @@index([name])
}

model RawMaizeBatch {
  id                  String        @id @default(cuid())
  batchNumber         String        @unique // e.g. RMB-2024-001
  
  // Supplier & Origin Traceability
  supplierId          String
  supplier            Supplier      @relation(fields: [supplierId], references: [id])
  farmOrigin          String?       // Specific farm/field identifier
  harvestDate         DateTime?
  
  // Truck & Weighbridge Data
  truckRegistration   String        // License plate
  driverName          String?
  driverPhone         String?
  
  grossWeight         Decimal       @db.Decimal(12, 3) // KG - truck + grain
  tareWeight          Decimal       @db.Decimal(12, 3) // KG - empty truck
  netWeight           Decimal       @db.Decimal(12, 3) // KG - actual grain weight
  
  // Inventory Status
  status              BatchStatus   @default(QUARANTINED)
  currentQuantity     Decimal       @db.Decimal(12, 3) // Remaining quantity
  
  // Storage Location
  siloId              String?
  silo                Silo?         @relation(fields: [siloId], references: [id])
  
  // Timestamps
  receivedAt          DateTime      @default(now())
  approvedAt          DateTime?
  expiryDate          DateTime?     // For FIFO enforcement
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  qualityControlLogs  QualityControlLog[]
  productionInputs    ProductionRunInput[]

  @@index([batchNumber])
  @@index([supplierId])
  @@index([status])
  @@index([receivedAt])
  @@index([expiryDate])
}

model QualityControlLog {
  id                  String        @id @default(cuid())
  
  // Link to Raw Batch
  rawMaizeBatchId     String
  rawMaizeBatch       RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id], onDelete: Cascade)
  
  // QC Test Results
  moistureContent     Decimal       @db.Decimal(5, 2) // % (e.g., 13.50%)
  aflatoxinLevel      Decimal       @db.Decimal(8, 2) // ppb (parts per billion)
  foreignMatter       Decimal       @db.Decimal(5, 2) // % (e.g., 0.50%)
  brokenKernels       Decimal?      @db.Decimal(5, 2) // % optional
  
  // Test Metadata
  status              QCStatus      @default(QUARANTINED)
  testedBy            String        // Inspector name or ID
  testDate            DateTime      @default(now())
  remarks             String?       @db.Text
  
  // Compliance Thresholds (for reference)
  // Moisture: < 14% (Approved), >= 14% (Rejected)
  // Aflatoxin: < 10 ppb (Approved), >= 10 ppb (Rejected)
  // Foreign Matter: < 2% (Approved), >= 2% (Rejected)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([rawMaizeBatchId])
  @@index([status])
  @@index([testDate])
}

model Silo {
  id                  String        @id @default(cuid())
  siloNumber          String        @unique // e.g. SILO-A1
  location            String        // Physical location in warehouse
  
  maxCapacity         Decimal       @db.Decimal(12, 3) // KG
  currentLevel        Decimal       @default(0.00) @db.Decimal(12, 3) // KG
  
  isActive            Boolean       @default(true)
  lastCleanedAt       DateTime?
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  rawMaizeBatches     RawMaizeBatch[]
  cleaningLogs        SiloCleaningLog[]

  @@index([siloNumber])
}

model SiloCleaningLog {
  id                  String        @id @default(cuid())
  
  siloId              String
  silo                Silo          @relation(fields: [siloId], references: [id], onDelete: Cascade)
  
  cleanedBy           String        // Operator name or ID
  cleaningDate        DateTime      @default(now())
  remarks             String?       @db.Text
  
  createdAt           DateTime      @default(now())

  @@index([siloId])
  @@index([cleaningDate])
}

// ============================================
// PRODUCTION & MILLING TRACEABILITY
// ============================================

model ProductionRun {
  id                  String        @id @default(cuid())
  runNumber           String        @unique // e.g. PR-2024-001
  
  // Production Line
  millingLine         String        // e.g. "Line A", "Line B"
  operatorName        String
  
  // Mass Balance Tracking
  totalRawInput       Decimal       @db.Decimal(12, 3) // KG - sum of all inputs
  totalFlourOutput    Decimal       @db.Decimal(12, 3) // KG - Grade 1 + Grade 2
  totalByProductOutput Decimal      @db.Decimal(12, 3) // KG - Bran + Germ
  moistureLoss        Decimal       @db.Decimal(12, 3) // KG - expected moisture loss
  variance            Decimal       @db.Decimal(12, 3) // KG - unaccounted difference
  variancePercent     Decimal       @db.Decimal(5, 2) // % - variance as percentage
  
  yieldEfficiency     Decimal       @db.Decimal(5, 2) // % - (output / input) * 100
  
  // Alert Flag
  varianceAlert       Boolean       @default(false) // True if variance > 3%
  
  // Timestamps
  startTime           DateTime
  endTime             DateTime?
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations - Traceability Links
  inputs              ProductionRunInput[]
  finishedGoods       FinishedGoodsBatch[]
  byProducts          ByProductBatch[]

  @@index([runNumber])
  @@index([startTime])
  @@index([varianceAlert])
}

model ProductionRunInput {
  id                  String        @id @default(cuid())
  
  productionRunId     String
  productionRun       ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
  
  rawMaizeBatchId     String
  rawMaizeBatch       RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id])
  
  quantityUsed        Decimal       @db.Decimal(12, 3) // KG consumed from this batch
  
  createdAt           DateTime      @default(now())

  @@index([productionRunId])
  @@index([rawMaizeBatchId])
}

model ByProductBatch {
  id                  String        @id @default(cuid())
  batchNumber         String        @unique // e.g. BP-2024-001
  
  productionRunId     String
  productionRun       ProductionRun @relation(fields: [productionRunId], references: [id])
  
  productType         String        // "MAIZE_BRAN", "MAIZE_GERM", "MIXED"
  quantity            Decimal       @db.Decimal(12, 3) // KG
  currentQuantity     Decimal       @db.Decimal(12, 3) // Remaining after sales
  
  unitPrice           Decimal       @default(0.00) @db.Decimal(10, 2)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([batchNumber])
  @@index([productionRunId])
}

// ============================================
// FINISHED GOODS - HIERARCHICAL TRACEABILITY
// ============================================

model FinishedGoodsBatch {
  id                  String        @id @default(cuid())
  batchNumber         String        @unique // e.g. FG-2024-001
  
  productionRunId     String
  productionRun       ProductionRun @relation(fields: [productionRunId], references: [id])
  
  productType         String        // "GRADE_1_FLOUR", "GRADE_2_FLOUR"
  totalQuantity       Decimal       @db.Decimal(12, 3) // KG - total produced
  currentQuantity     Decimal       @db.Decimal(12, 3) // KG - remaining in stock
  
  packagingDate       DateTime      @default(now())
  expiryDate          DateTime      // For FIFO enforcement
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations - Hierarchical Structure
  pallets             Pallet[]

  @@index([batchNumber])
  @@index([productionRunId])
  @@index([expiryDate])
}

model Pallet {
  id                  String        @id @default(cuid())
  palletBarcode       String        @unique // Scannable barcode
  
  finishedGoodsBatchId String
  finishedGoodsBatch  FinishedGoodsBatch @relation(fields: [finishedGoodsBatchId], references: [id])
  
  totalWeight         Decimal       @db.Decimal(12, 3) // KG
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  bales               Bale[]
  dispatchItems       DispatchItem[]

  @@index([palletBarcode])
  @@index([finishedGoodsBatchId])
}

model Bale {
  id                  String        @id @default(cuid())
  baleBarcode         String        @unique // Scannable barcode
  
  palletId            String
  pallet              Pallet        @relation(fields: [palletId], references: [id], onDelete: Cascade)
  
  totalWeight         Decimal       @db.Decimal(12, 3) // KG
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  bags                Bag[]

  @@index([baleBarcode])
  @@index([palletId])
}

model Bag {
  id                  String        @id @default(cuid())
  bagBarcode          String        @unique // Scannable barcode - FINAL RETAIL UNIT
  
  baleId              String
  bale                Bale          @relation(fields: [baleId], references: [id], onDelete: Cascade)
  
  weight              Decimal       @db.Decimal(12, 3) // KG (e.g., 2.000 KG)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([bagBarcode])
  @@index([baleId])
}

// ============================================
// DISPATCH & CUSTOMER DELIVERY TRACEABILITY
// ============================================

model DispatchLog {
  id                  String        @id @default(cuid())
  dispatchNumber      String        @unique // e.g. DISP-2024-001

  customerId          String
  customer            Customer      @relation(fields: [customerId], references: [id])

  // Optional linkage to sales invoice for strict forward trace.
  invoiceId           String?
  invoice             Invoice?      @relation(fields: [invoiceId], references: [id])

  truckRegistration   String
  driverName          String
  driverPhone         String?

  status              DispatchStatus @default(PENDING)

  loadedAt            DateTime?
  deliveredAt         DateTime?

  deliveryAddress     String        @db.Text
  remarks             String?       @db.Text

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  items               DispatchItem[]

  @@index([dispatchNumber])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([loadedAt])
}


model DispatchItem {
  id                  String        @id @default(cuid())
  
  dispatchLogId       String
  dispatchLog         DispatchLog   @relation(fields: [dispatchLogId], references: [id], onDelete: Cascade)
  
  palletId            String
  pallet              Pallet        @relation(fields: [palletId], references: [id])
  
  quantity            Decimal       @db.Decimal(12, 3) // KG
  
  createdAt           DateTime      @default(now())

  @@index([dispatchLogId])
  @@index([palletId])
}

// ============================================
// LEGACY MODELS (Updated with Relations)
// ============================================

model ProductionBatch {
  id                String    @id @default(cuid())
  batchNumber       String    @unique
  
  // Production metrics (in KG) - LEGACY - Use ProductionRun instead
  rawMaizeConsumed  Decimal   @db.Decimal(12, 3)
  grade1Produced    Decimal   @db.Decimal(12, 3)
  grade2Produced    Decimal   @db.Decimal(12, 3)
  maizeJamProduced  Decimal   @db.Decimal(12, 3)
  wasteLoss         Decimal   @db.Decimal(12, 3)
  efficiency        Decimal   @db.Decimal(5, 2) // Output % efficiency

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  email     String?   @unique
  phone     String?
  address   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  invoices  Invoice[]
  dispatches DispatchLog[]
}

model Invoice {
  id            String    @id @default(cuid())

  invoiceNumber String    @unique

  // Relations
  dispatches   DispatchLog[]


  // Money fields
  subtotal      Decimal   @db.Decimal(10, 2)
  tax           Decimal   @db.Decimal(10, 2)
  total         Decimal   @db.Decimal(10, 2)

  status        String    @default("DRAFT") // DRAFT, ISSUED, PAID, VOID
  issuedAt      DateTime?

  // Relations
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdById   String
  createdBy     User      @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
