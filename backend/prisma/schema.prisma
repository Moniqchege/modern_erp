generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERADMIN
  MAIN_STORE_MANAGER
  MAIZE_STORE_MANAGER
  PACKAGING_STORE_MANAGER
  DISPATCH_STORE_MANAGER
  MANAGER
  EMPLOYEE
  QC_INSPECTOR
  WAREHOUSE_OPERATOR
  PROCUREMENT_OFFICER
  FINANCE_DIRECTOR
  LAB_TECHNICIAN
  WEIGHBRIDGE_OPERATOR
}

enum StockTransferStatus {
  PENDING
  APPROVED_IN_TRANSIT
  COMPLETED
  REJECTED
  RECEIPT_REJECTED
  PENDING_CORRECTION
}

enum ItemType {
  RAW_MATERIAL
  FINISHED_GOOD
  BY_PRODUCT
  PACKETS_2KG
  PACKETS_1KG
  KHAKI_BALER_2KG
  KHAKI_BALER_1KG
  NYLON_BALER_1KG
  NYLON_BALER_2KG
  BAG_5KG
  BAG_10KG
  LAMINATED_BALER
  BAG_50KG
  BAG_90KG
  CLEAR_TAPES
  GLUE
}

enum UnitOfMeasure {
  KG
  BAG
  PIECES
  BALE
  UNIT
  MT
  GRAMS
  L
}

enum QCStatus {
  QUARANTINED
  APPROVED
  REJECTED
}

enum BatchStatus {
  QUARANTINED
  APPROVED
  REJECTED
  IN_PRODUCTION
  CONSUMED
}

enum DispatchStatus {
  PENDING
  LOADED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String
  role  UserRole @default(EMPLOYEE)

  passwordHash       String?
  forcePasswordReset Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices                Invoice[]              @relation("InvoiceCreatedBy")
  stockTransfersRequested StockTransferRequest[] @relation("StockTransferRequestedBy")
  stockTransfersApproved  StockTransferRequest[] @relation("StockTransferApprovedBy")
  stockTransfersReceiptRejected StockTransferRequest[] @relation("StockTransferReceiptRejectedBy")
  storeManagerAssignment  StoreManagerAssignment?
}

model OtpCode {
  id         String    @id @default(cuid())
  userId     String    @unique
  code       String
  expiresAt  DateTime
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InventoryMovementType {
  RECEIPT
  ISSUE_TO_PRODUCTION
  ISSUE_TO_PACKAGING
  SALES_DISPATCH
  ADJUSTMENT
}

enum InventoryPriceType {
  BUYING
  SELLING
}

model InventoryPriceHistory {
  id     String        @id @default(cuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  priceType     InventoryPriceType
  unitPrice     Decimal            @db.Decimal(10, 2)
  effectiveDate DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([itemId, priceType, effectiveDate])
}

model InventoryItem {
  id          String        @id @default(cuid())
  sku         String        @unique
  name        String
  description String?
  type        ItemType      @default(FINISHED_GOOD)
  unit        UnitOfMeasure @default(KG)

  quantity               Decimal                             @default(0.00) @db.Decimal(12, 3)
  packagingRunInputs     PackagingRunFinishedProductInput[]
  packagingRunOutputs    PackagingRunFinishedProductOutput[]
  productionBatchOutputs ProductionBatchOutput[]
  reorderLevel           Decimal?                            @db.Decimal(12, 3)
  reorderQuantity        Decimal?                            @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory  InventoryPriceHistory[]
  movements     InventoryMovement[]
  storeBalances StoreInventoryBalance[]
  transferItems StockTransferItem[]
}

model InventoryMovement {
  id     String        @id @default(cuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  movementType     InventoryMovementType
  quantityDelta    Decimal               @db.Decimal(12, 3) 
  unitPriceApplied Decimal               @db.Decimal(10, 2) 
  movementAt       DateTime              @default(now())

  supplierId      String?
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  grnLineId       String?
  grnLine         GoodsReceivedNoteLine? @relation(fields: [grnLineId], references: [id])
  productionRunId String?
  packagingRunId  String?
  packagingRun    PackagingRun?          @relation(fields: [packagingRunId], references: [id])
  dispatchLogId   String?

  locationId String?
  location   InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  stockTransferRequestId String?
  stockTransferRequest   StockTransferRequest? @relation(fields: [stockTransferRequestId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, movementAt])
  @@index([movementType, movementAt])
  @@index([locationId, itemId])
}

// ============================================
// MULTI-STORE INVENTORY & STOCK TRANSFERS
// ============================================

model InventoryLocation {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String    @db.VarChar(255)
  description String?   @db.VarChar(1000)
  address     String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  isLegacy    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  balances             StoreInventoryBalance[]
  movements            InventoryMovement[]
  sourceTransfers      StockTransferRequest[]   @relation("TransferSourceStore")
  destinationTransfers StockTransferRequest[]   @relation("TransferDestinationStore")
  managerAssignments   StoreManagerAssignment[]
  auditLogs            StoreAuditLog[]
}

model StoreManagerAssignment {
  id         String            @id @default(cuid())
  userId     String            @unique
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId    String
  store      InventoryLocation @relation(fields: [storeId], references: [id], onDelete: Cascade)
  assignedAt DateTime          @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

enum StoreAuditAction {
  STORE_CREATED
  STORE_UPDATED
  STORE_ACTIVATED
  STORE_DEACTIVATED
  MANAGER_ASSIGNED
  MANAGER_REMOVED
}

model StoreAuditLog {
  id               String           @id @default(cuid())
  action           StoreAuditAction
  storeId          String
  store            InventoryLocation @relation(fields: [storeId], references: [id], onDelete: Cascade)
  performedByUserId String
  snapshot         Json
  createdAt        DateTime         @default(now())

  @@index([storeId, createdAt])
  @@index([performedByUserId])
}

model StoreInventoryBalance {
  id          String            @id @default(cuid())
  itemId      String
  item        InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId  String
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  physicalQty Decimal           @default(0) @db.Decimal(12, 3)
  transitQty  Decimal           @default(0) @db.Decimal(12, 3)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([itemId, locationId])
  @@index([locationId])
}

model StockTransferRequest {
  id                    String              @id @default(cuid())
  requestNumber         String              @unique
  sourceLocationId      String
  sourceLocation        InventoryLocation   @relation("TransferSourceStore", fields: [sourceLocationId], references: [id])
  destinationLocationId String
  destinationLocation   InventoryLocation   @relation("TransferDestinationStore", fields: [destinationLocationId], references: [id])
  requestedByUserId     String
  requestedBy           User                @relation("StockTransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUserId      String?
  approvedBy            User?               @relation("StockTransferApprovedBy", fields: [approvedByUserId], references: [id])
  status                StockTransferStatus @default(PENDING)
  rejectionReason       String?             @db.Text
  notes                 String?             @db.Text
  approvedAt            DateTime?
  completedAt           DateTime?

  /// Set when receiving store rejects a delivered transfer
  receiptRejectionReason  String?           @db.Text
  receiptRejectedByUserId String?
  receiptRejectedBy       User?             @relation("StockTransferReceiptRejectedBy", fields: [receiptRejectedByUserId], references: [id])
  receiptRejectedAt       DateTime?

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  items         StockTransferItem[]
  movements     InventoryMovement[]
  discrepancies StockTransferDiscrepancy[]

  @@index([status, createdAt])
  @@index([sourceLocationId])
  @@index([destinationLocationId])
  @@index([requestedByUserId])
}

model StockTransferItem {
  id              String               @id @default(cuid())
  transferId      String
  transfer        StockTransferRequest @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemId          String
  item            InventoryItem        @relation(fields: [itemId], references: [id])
  qtyRequested    Decimal              @db.Decimal(12, 3)
  qtyIssued       Decimal?             @db.Decimal(12, 3)
  /// Reason provided by main store manager when qtyIssued < qtyRequested
  partialIssueReason String?           @db.Text
  qtyReceived     Decimal?             @db.Decimal(12, 3)
  discrepancyNote String?              @db.Text
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([transferId])
  @@index([itemId])
}

model StockTransferDiscrepancy {
  id            String               @id @default(cuid())
  transferId    String
  transfer      StockTransferRequest @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemId        String
  qtyIssued     Decimal              @db.Decimal(12, 3)
  qtyReceived   Decimal              @db.Decimal(12, 3)
  qtyShort      Decimal              @db.Decimal(12, 3)
  notedByUserId String?
  notedAt       DateTime             @default(now())

  @@index([transferId])
}

// ============================================
// TRACEABILITY MODULE - SUPPLIERS & RAW MATERIALS
// ============================================

model Supplier {
  id             String  @id @default(cuid())
  code           String  @unique 
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String? @db.Text
  farmLocation   String?
  certifications String? @db.Text

  businessRegistrationNo String?
  taxPin                 String?
  vatNumber              String?
  bankName               String?
  bankAccountNo          String?
  bankBranch             String?
  bankSwiftCode          String?
  onboardingStatus       SupplierOnboardingStatus @default(PENDING)
  onboardingNotes        String?                  @db.Text
  qaApprovedAt           DateTime?
  financeApprovedAt      DateTime?
  activatedAt            DateTime?

  lockedAt DateTime?
  lockedBy String?

  status    SupplierStatus @default(INACTIVE)
  createdAt DateTime       @default(now())

  updatedAt DateTime @updatedAt

  rawMaizeBatches      RawMaizeBatch[]
  complianceDocuments  SupplierComplianceDocument[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  supplierInvoices     SupplierInvoice[]
  inventoryMovements   InventoryMovement[]
  onboardingAuditLogs  ProcurementAuditLog[]        @relation("SupplierAudit")
  suppliedItems        SupplierSuppliedItem[]

  @@index([code])
  @@index([name])
  @@index([onboardingStatus])
  @@index([status])
  @@index([taxPin])
}

model RawMaizeBatch {
  id          String @id @default(cuid())
  batchNumber String @unique

  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  farmOrigin  String? 
  harvestDate DateTime?

  truckRegistration String 
  driverName        String?
  driverPhone       String?

  grossWeight Decimal @db.Decimal(12, 3) 
  tareWeight  Decimal @db.Decimal(12, 3) 
  netWeight   Decimal @db.Decimal(12, 3)

  status          BatchStatus @default(QUARANTINED)
  currentQuantity Decimal     @db.Decimal(12, 3)

  siloId String?
  silo   Silo?   @relation(fields: [siloId], references: [id])

  receivedAt DateTime  @default(now())
  approvedAt DateTime?
  expiryDate DateTime? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderId String?

  qualityControlLogs   QualityControlLog[]
  productionInputs     ProductionRunInput[]
  weighbridgeTickets   WeighbridgeTicket[]
  procurementQcResults ProcurementQCLabResult[]

  @@index([batchNumber])
  @@index([supplierId])
  @@index([status])
  @@index([receivedAt])
  @@index([expiryDate])
}

model QualityControlLog {
  id String @id @default(cuid())

  rawMaizeBatchId String
  rawMaizeBatch   RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id], onDelete: Cascade)

  moistureContent Decimal  @db.Decimal(5, 2) 
  aflatoxinLevel  Decimal  @db.Decimal(8, 2) 
  foreignMatter   Decimal  @db.Decimal(5, 2) 
  brokenKernels   Decimal? @db.Decimal(5, 2) 

  status   QCStatus @default(QUARANTINED)
  testedBy String // Inspector name or ID
  testDate DateTime @default(now())
  remarks  String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rawMaizeBatchId])
  @@index([status])
  @@index([testDate])
}

model Silo {
  id         String @id @default(cuid())
  siloNumber String @unique 
  location   String 

  maxCapacity  Decimal @db.Decimal(12, 3) 
  currentLevel Decimal @default(0.00) @db.Decimal(12, 3) 

  isActive      Boolean   @default(true)
  lastCleanedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawMaizeBatches RawMaizeBatch[]
  cleaningLogs    SiloCleaningLog[]

  @@index([siloNumber])
}

model SiloCleaningLog {
  id String @id @default(cuid())

  siloId String
  silo   Silo   @relation(fields: [siloId], references: [id], onDelete: Cascade)

  cleanedBy    String 
  cleaningDate DateTime @default(now())
  remarks      String?  @db.Text

  createdAt DateTime @default(now())

  @@index([siloId])
  @@index([cleaningDate])
}

// ============================================
// PRODUCTION & MILLING TRACEABILITY
// ============================================

model ProductionRun {
  id        String @id @default(cuid())
  runNumber String @unique

  millingLine  String 
  operatorName String

  totalRawInput        Decimal @db.Decimal(12, 3)
  totalFlourOutput     Decimal @db.Decimal(12, 3)
  totalByProductOutput Decimal @db.Decimal(12, 3) 
  moistureLoss         Decimal @db.Decimal(12, 3) 
  variance             Decimal @db.Decimal(12, 3)
  variancePercent      Decimal @db.Decimal(5, 2) 

  yieldEfficiency Decimal @db.Decimal(5, 2) 

  varianceAlert Boolean @default(false) 

  startTime DateTime
  endTime   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inputs        ProductionRunInput[]
  finishedGoods FinishedGoodsBatch[]
  byProducts    ByProductBatch[]

  @@index([runNumber])
  @@index([startTime])
  @@index([varianceAlert])
}

model ProductionRunInput {
  id String @id @default(cuid())

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  rawMaizeBatchId String
  rawMaizeBatch   RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id])

  quantityUsed Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())

  @@index([productionRunId])
  @@index([rawMaizeBatchId])
}

model ByProductBatch {
  id          String @id @default(cuid())
  batchNumber String @unique

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id])

  productType     String 
  quantity        Decimal @db.Decimal(12, 3) 
  currentQuantity Decimal @db.Decimal(12, 3)

  unitPrice Decimal @default(0.00) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchNumber])
  @@index([productionRunId])
}

// ============================================
// FINISHED GOODS - HIERARCHICAL TRACEABILITY
// ============================================

model FinishedGoodsBatch {
  id          String @id @default(cuid())
  batchNumber String @unique 

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id])

  productType     String 
  totalQuantity   Decimal @db.Decimal(12, 3) 
  currentQuantity Decimal @db.Decimal(12, 3) 

  packagingDate DateTime @default(now())
  expiryDate    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pallets Pallet[]

  @@index([batchNumber])
  @@index([productionRunId])
  @@index([expiryDate])
}

model Pallet {
  id            String @id @default(cuid())
  palletBarcode String @unique 

  finishedGoodsBatchId String
  finishedGoodsBatch   FinishedGoodsBatch @relation(fields: [finishedGoodsBatchId], references: [id])

  totalWeight Decimal @db.Decimal(12, 3) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bales         Bale[]
  dispatchItems DispatchItem[]

  @@index([palletBarcode])
  @@index([finishedGoodsBatchId])
}

model Bale {
  id          String @id @default(cuid())
  baleBarcode String @unique 

  palletId String
  pallet   Pallet @relation(fields: [palletId], references: [id], onDelete: Cascade)

  totalWeight Decimal @db.Decimal(12, 3) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bags Bag[]

  @@index([baleBarcode])
  @@index([palletId])
}

model Bag {
  id         String @id @default(cuid())
  bagBarcode String @unique 

  baleId String
  bale   Bale   @relation(fields: [baleId], references: [id], onDelete: Cascade)

  weight Decimal @db.Decimal(12, 3) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bagBarcode])
  @@index([baleId])
}

// ============================================
// DISPATCH & CUSTOMER DELIVERY TRACEABILITY
// ============================================

model DispatchLog {
  id             String @id @default(cuid())
  dispatchNumber String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  truckRegistration String
  driverName        String
  driverPhone       String?

  status DispatchStatus @default(PENDING)

  loadedAt    DateTime?
  deliveredAt DateTime?

  deliveryAddress String  @db.Text
  remarks         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DispatchItem[]

  @@index([dispatchNumber])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([loadedAt])
}

model DispatchItem {
  id String @id @default(cuid())

  dispatchLogId String
  dispatchLog   DispatchLog @relation(fields: [dispatchLogId], references: [id], onDelete: Cascade)

  palletId String
  pallet   Pallet @relation(fields: [palletId], references: [id])

  quantity Decimal @db.Decimal(12, 3) // KG

  createdAt DateTime @default(now())

  @@index([dispatchLogId])
  @@index([palletId])
}

// ============================================
// LEGACY MODELS (Updated with Relations)
// ============================================

model ProductionBatch {
  id          String @id @default(cuid())
  batchNumber String @unique

  rawMaizeConsumed Decimal @db.Decimal(12, 3)
  wasteLoss        Decimal @db.Decimal(12, 3)
  efficiency       Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outputs ProductionBatchOutput[]

  @@index([batchNumber])
}

model ProductionBatchOutput {
  id                String          @id @default(cuid())
  productionBatchId String
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantityKg Decimal @db.Decimal(12, 3)

  @@index([productionBatchId])
}

// ============================================
// PACKAGING — bulk flour to 24kg bales
// ============================================

model PackagingRun {
  id        String @id @default(cuid())
  runNumber String @unique

  operatorName String
  baleWeightKg Decimal @default(24) @db.Decimal(12, 3)

  flourSpillage Decimal @default(0) @db.Decimal(12, 3)

  packagingMaterialReceived  Decimal @default(0) @db.Decimal(12, 3)
  packagingMaterialConsumed  Decimal @default(0) @db.Decimal(12, 3)
  packagingMaterialDestroyed Decimal @default(0) @db.Decimal(12, 3)

  totalPackagedKg Decimal  @db.Decimal(12, 3)
  yieldPercent    Decimal  @db.Decimal(5, 2)
  electricityKwh  Decimal? @db.Decimal(10, 3)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements              InventoryMovement[]
  finishedProductInputs  PackagingRunFinishedProductInput[]
  finishedProductOutputs PackagingRunFinishedProductOutput[]

  @@index([runNumber])
  @@index([createdAt])
}

// ============================================
// PACKAGING — normalized per-finished-product breakdown
// ============================================

model PackagingRunFinishedProductInput {
  id                  String        @id @default(cuid())
  packagingRunId      String
  packagingRun        PackagingRun  @relation(fields: [packagingRunId], references: [id], onDelete: Cascade)
  inventoryItemId     String
  inventoryItem       InventoryItem @relation(fields: [inventoryItemId], references: [id])
  finishedProductName String        @db.VarChar(255)
  flourConsumedKg     Decimal       @db.Decimal(12, 3)
  flourSpillageKg     Decimal       @default(0) @db.Decimal(12, 3)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([packagingRunId])
  @@index([finishedProductName])
}

model PackagingRunFinishedProductOutput {
  id String @id @default(cuid())

  packagingRunId      String
  packagingRun        PackagingRun  @relation(fields: [packagingRunId], references: [id], onDelete: Cascade)
  finishedProductName String        @db.VarChar(255)

  typeKey             String? @default("UNKNOWN")

  inventoryItemId String?
  inventoryItem    InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  balesProduced       Int
  packagedKg          Decimal       @db.Decimal(12, 3)
  kgPerUnit Decimal @default(24) @db.Decimal(12, 3)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([packagingRunId])
  @@index([finishedProductName])
}


// ============================================
// CUSTOMERS & SALES MODULE (Maize Flour Plant)
// ============================================

enum CustomerType {
  DISTRIBUTOR
  WHOLESALER
  RETAILER
  WALK_IN
}

enum CustomerAccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SalesOrderPaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  FULFILLED
}

enum SalesDispatchStatus {
  PENDING
  LOADING
  DISPATCHED
  DELIVERED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  VOID
  OVERDUE
}

enum CustomerPaymentMethod {
  MPESA
  BANK
  CASH
  CHEQUE
}

model Customer {
  id      String  @id @default(cuid())
  name    String
  email   String? @unique
  phone   String?
  address String?

  type           CustomerType          @default(RETAILER)
  creditLimit    Decimal               @default(0) @db.Decimal(12, 2)
  currentBalance Decimal               @default(0) @db.Decimal(12, 2)
  creditDays     Int                   @default(30)
  taxPin         String?               @db.VarChar(32)
  status         CustomerAccountStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices    Invoice[]
  dispatches  DispatchLog[]
  salesOrders SalesOrder[]
  payments    CustomerPayment[]

  @@index([type])
  @@index([status])
  @@index([currentBalance])
}

model SalesProduct {
  id          String  @id @default(cuid())
  sku         String  @unique
  name        String
  description String? @db.Text
  basePrice   Decimal @db.Decimal(10, 2)
  unit        String  @default("bag")
  category    String  @default("FLOUR") @db.VarChar(64)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderLines SalesOrderItem[]

  @@index([sku])
  @@index([isActive])
}

model SalesOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderDate      DateTime                @default(now())
  subtotal       Decimal                 @db.Decimal(12, 2)
  taxAmount      Decimal                 @db.Decimal(12, 2)
  totalAmount    Decimal                 @db.Decimal(12, 2)
  paymentStatus  SalesOrderPaymentStatus @default(PENDING)
  orderStatus    SalesOrderStatus        @default(DRAFT)
  dispatchStatus SalesDispatchStatus     @default(PENDING)

  items   SalesOrderItem[]
  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([dispatchStatus])
  @@index([orderDate])
}

model SalesOrderItem {
  id String @id @default(cuid())

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  productSku       String
  salesProduct     SalesProduct? @relation(fields: [productSku], references: [sku])
  quantity         Decimal       @db.Decimal(12, 3)
  unitPrice        Decimal       @db.Decimal(10, 2)
  discountPercent  Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal        Decimal       @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([salesOrderId])
  @@index([productSku])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  dispatches    DispatchLog[]

  subtotal  Decimal @db.Decimal(10, 2)
  tax       Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
  amountDue Decimal @db.Decimal(10, 2)
  status    InvoiceStatus @default(DRAFT)

  dueDate  DateTime?
  issuedAt DateTime?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salesOrderId String?    @unique
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  payments CustomerPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model CustomerPayment {
  id String @id @default(cuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  amountPaid           Decimal               @db.Decimal(12, 2)
  paymentMethod        CustomerPaymentMethod
  transactionReference String?               @db.VarChar(128)
  paidAt               DateTime              @default(now())

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([invoiceId])
  @@index([paidAt])
}

// ============================================
// PROCUREMENT & SUPPLIER MANAGEMENT MODULE
// ============================================

enum SupplierOnboardingStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum ComplianceDocumentStatus {
  ACTIVE
  EXPIRING_SOON
  NON_COMPLIANT
}

enum ComplianceDocumentType {
  FOOD_SAFETY
  KEBS_CERTIFICATE
  ISO
  ORGANIC
  GLOBALGAP
  TAX_COMPLIANCE
  OTHER
}

enum ProcurementCategory {
  RAW_MATERIAL
  PACKAGING
  MILLING_CONSUMABLE
  ENGINEERING_SPARE
}

enum RawMaizeGrade {
  GRADE_A
  GRADE_B
  GRADE_C
  REJECT
}

enum PackagingBagSize {
  KG_1
  KG_2
  KG_5
  KG_10
  KG_24
  KG_50
}

enum RequisitionSource {
  LOW_STOCK_AUTO
  MANUAL_PLANT
  MANUAL_PROCUREMENT
}

enum RequisitionStatus {
  DRAFT
  PENDING_HEAD_PROCUREMENT
  PENDING_FINANCE
  APPROVED
  REJECTED
  CONVERTED_TO_PO
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
  CANCELLED
}

enum CurrencyCode {
  KES
  USD
  EUR
  UGX
  TZS
}

enum WeighbridgeDirection {
  INBOUND
  OUTBOUND
}

enum ProcurementQCStatus {
  PENDING
  PASSED
  FAILED_CONDITIONAL
  FULL_REJECTION
}

enum GrnStatus {
  DRAFT
  PENDING_QC
  POSTED
  REJECTED
  CANCELLED
}

enum ThreeWayMatchStatus {
  PENDING
  MATCHED
  PRICE_DISCREPANCY
  QUANTITY_DISCREPANCY
  BOTH_DISCREPANCY
  APPROVED_FOR_PAYMENT
  REJECTED
}

enum PaymentVoucherStatus {
  DRAFT
  APPROVED
  PAID
  VOID
}

enum DomainEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum ProcurementAuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  APPROVE
  REJECT
  POST
  VOID
}

model SupplierComplianceDocument {
  id           String                   @id @default(cuid())
  supplierId   String
  supplier     Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  documentType ComplianceDocumentType
  title        String
  fileUrl      String?                  @db.Text
  referenceNo  String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  status       ComplianceDocumentStatus @default(ACTIVE)
  notes        String?                  @db.Text
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([supplierId])
  @@index([expiresAt])
  @@index([status])
}

model ProcurementItemProfile {
  id                 String              @id @default(cuid())
  inventoryItemId    String?             @unique
  sku                String              @unique
  name               String
  category           ProcurementCategory
  unit               UnitOfMeasure       @default(KG)
  description        String?             @db.Text
  lowStockThreshold  Decimal?            @db.Decimal(12, 3)
  reorderQuantity    Decimal?            @db.Decimal(12, 3)
  rawMaizeGrade      RawMaizeGrade?
  packagingBagSize   PackagingBagSize?
  brandingDesignCode String?
  moistureMaxPct     Decimal?            @db.Decimal(5, 2)
  aflatoxinMaxPpb    Decimal?            @db.Decimal(8, 2)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  requisitionLines PurchaseRequisitionLine[]
  poLines          PurchaseOrderLine[]
  supplierLinks    SupplierSuppliedItem[]

  @@index([category])
  @@index([sku])
}

model SupplierSuppliedItem {
  id            String                 @id @default(cuid())
  supplierId    String
  supplier      Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  itemProfileId String
  itemProfile   ProcurementItemProfile @relation(fields: [itemProfileId], references: [id], onDelete: Cascade)
  isPreferred   Boolean                @default(false)
  leadTimeDays  Int?
  minOrderQty   Decimal?               @db.Decimal(12, 3)
  lastUnitPrice Decimal?               @db.Decimal(12, 2)
  notes         String?                @db.Text
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([supplierId, itemProfileId])
  @@index([supplierId])
  @@index([itemProfileId])
}

model ApprovalThreshold {
  id                 String       @id @default(cuid())
  name               String
  currency           CurrencyCode @default(KES)
  headProcurementMax Decimal      @db.Decimal(14, 2)
  financeDirectorMin Decimal      @db.Decimal(14, 2)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PurchaseRequisition {
  id              String            @id @default(cuid())
  requisitionNo   String            @unique
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  requestedBy     String
  department      String?
  source          RequisitionSource @default(MANUAL_PROCUREMENT)
  status          RequisitionStatus @default(DRAFT)
  justification   String?           @db.Text
  requiredByDate  DateTime?
  estimatedTotal  Decimal           @default(0) @db.Decimal(14, 2)
  currency        CurrencyCode      @default(KES)
  rejectionReason String?           @db.Text
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  lines          PurchaseRequisitionLine[]
  approvals      ProcurementApproval[]
  purchaseOrders PurchaseOrder[]

  @@index([requisitionNo])
  @@index([status])
  @@index([supplierId])
}

model PurchaseRequisitionLine {
  id                String                 @id @default(cuid())
  requisitionId     String
  requisition       PurchaseRequisition    @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemProfileId     String
  itemProfile       ProcurementItemProfile @relation(fields: [itemProfileId], references: [id])
  quantity          Decimal                @db.Decimal(12, 3)
  unitPriceEstimate Decimal?               @db.Decimal(12, 2)
  lineTotalEstimate Decimal?               @db.Decimal(14, 2)
  notes             String?                @db.Text
  createdAt         DateTime               @default(now())

  @@index([requisitionId])
}

model ProcurementApproval {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  level        String
  approverId   String?
  approverName String
  decision     String
  comments     String?  @db.Text
  decidedAt    DateTime @default(now())

  requisitionId   String?
  requisition     PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([requisitionId])
  @@index([purchaseOrderId])
}

model PurchaseOrder {
  id                 String               @id @default(cuid())
  poNumber           String               @unique
  supplierId         String
  supplier           Supplier             @relation(fields: [supplierId], references: [id])
  requisitionId      String?
  requisition        PurchaseRequisition? @relation(fields: [requisitionId], references: [id])
  status             PurchaseOrderStatus  @default(DRAFT)
  currency           CurrencyCode         @default(KES)
  exchangeRate       Decimal              @default(1) @db.Decimal(12, 6)
  subtotal           Decimal              @default(0) @db.Decimal(14, 2)
  taxRate            Decimal              @default(16) @db.Decimal(5, 2)
  taxAmount          Decimal              @default(0) @db.Decimal(14, 2)
  totalAmount        Decimal              @default(0) @db.Decimal(14, 2)
  termsAndConditions String?              @db.Text
  expectedDelivery   DateTime?
  issuedAt           DateTime?
  issuedBy           String?
  pdfUrl             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  lines              PurchaseOrderLine[]
  weighbridgeTickets WeighbridgeTicket[]
  grns               GoodsReceivedNote[]
  supplierInvoices   SupplierInvoice[]
  approvals          ProcurementApproval[]

  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderLine {
  id               String                 @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemProfileId    String
  itemProfile      ProcurementItemProfile @relation(fields: [itemProfileId], references: [id])
  description      String?
  quantity         Decimal                @db.Decimal(12, 3)
  unitPrice        Decimal                @db.Decimal(12, 2)
  taxAmount        Decimal                @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal                @db.Decimal(14, 2)
  quantityReceived Decimal                @default(0) @db.Decimal(12, 3)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  grnLines GoodsReceivedNoteLine[]

  @@index([purchaseOrderId])
}

model WeighbridgeTicket {
  id                String               @id @default(cuid())
  ticketNumber      String               @unique
  direction         WeighbridgeDirection @default(INBOUND)
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  rawMaizeBatchId   String?
  rawMaizeBatch     RawMaizeBatch?       @relation(fields: [rawMaizeBatchId], references: [id])
  truckRegistration String
  driverName        String?
  grossWeightKg     Decimal              @db.Decimal(12, 3)
  tareWeightKg      Decimal              @db.Decimal(12, 3)
  netWeightKg       Decimal              @db.Decimal(12, 3)
  weighedInAt       DateTime             @default(now())
  weighedOutAt      DateTime?
  operatorName      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  grns      GoodsReceivedNote[]
  qcResults ProcurementQCLabResult[]

  @@index([ticketNumber])
  @@index([purchaseOrderId])
}

model ProcurementQCLabResult {
  id                   String              @id @default(cuid())
  qcNumber             String              @unique
  category             ProcurementCategory
  weighbridgeTicketId  String?
  weighbridgeTicket    WeighbridgeTicket?  @relation(fields: [weighbridgeTicketId], references: [id])
  rawMaizeBatchId      String?
  rawMaizeBatch        RawMaizeBatch?      @relation(fields: [rawMaizeBatchId], references: [id])
  grnId                String?
  grn                  GoodsReceivedNote?  @relation(fields: [grnId], references: [id])
  status               ProcurementQCStatus @default(PENDING)
  testedBy             String
  testedAt             DateTime            @default(now())
  moistureContentPct   Decimal?            @db.Decimal(5, 2)
  aflatoxinPpb         Decimal?            @db.Decimal(8, 2)
  rottenBrokenPct      Decimal?            @db.Decimal(5, 2)
  foreignMatterPct     Decimal?            @db.Decimal(5, 2)
  liveInsectsCount     Int?
  assignedGrade        RawMaizeGrade?
  tensileStrengthN     Decimal?            @db.Decimal(10, 2)
  printAlignmentScore  Decimal?            @db.Decimal(5, 2)
  dimensionAccuracyMm  Decimal?            @db.Decimal(8, 2)
  priceDeductionPct    Decimal?            @db.Decimal(5, 2)
  priceDeductionAmount Decimal?            @db.Decimal(14, 2)
  acceptedQuantity     Decimal?            @db.Decimal(12, 3)
  rejectionNote        String?             @db.Text
  remarks              String?             @db.Text
  blocksInventoryPost  Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([qcNumber])
  @@index([status])
  @@index([rawMaizeBatchId])
}

model GoodsReceivedNote {
  id                  String             @id @default(cuid())
  grnNumber           String             @unique
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  weighbridgeTicketId String?
  weighbridgeTicket   WeighbridgeTicket? @relation(fields: [weighbridgeTicketId], references: [id])
  deliverySequence    Int                @default(1)
  status              GrnStatus          @default(PENDING_QC)
  receivedAt          DateTime           @default(now())
  receivedBy          String
  lotNumber           String?
  batchTraceCode      String?
  netWeightAccepted   Decimal?           @db.Decimal(12, 3)
  postedAt            DateTime?
  postedBy            String?
  notes               String?            @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  lines           GoodsReceivedNoteLine[]
  qcResults       ProcurementQCLabResult[]
  threeWayMatches ThreeWayMatch[]

  @@index([grnNumber])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([lotNumber])
  @@index([batchTraceCode])
}

model GoodsReceivedNoteLine {
  id                  String            @id @default(cuid())
  grnId               String
  grn                 GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  quantityAccepted    Decimal           @db.Decimal(12, 3)
  quantityRejected    Decimal           @default(0) @db.Decimal(12, 3)
  unitPriceApplied    Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(14, 2)
  lotNumber           String?
  createdAt           DateTime          @default(now())

  inventoryMovements InventoryMovement[]

  @@index([grnId])
  @@index([purchaseOrderLineId])
}

model SupplierInvoice {
  id              String        @id @default(cuid())
  invoiceNumber   String
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  invoiceDate     DateTime
  dueDate         DateTime?
  currency        CurrencyCode  @default(KES)
  subtotal        Decimal       @db.Decimal(14, 2)
  taxAmount       Decimal       @db.Decimal(14, 2)
  totalAmount     Decimal       @db.Decimal(14, 2)
  fileUrl         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  threeWayMatches ThreeWayMatch[]
  paymentVouchers PaymentVoucher[]

  @@unique([supplierId, invoiceNumber])
  @@index([purchaseOrderId])
}

model ThreeWayMatch {
  id                  String              @id @default(cuid())
  matchNumber         String              @unique
  purchaseOrderId     String
  grnId               String
  grn                 GoodsReceivedNote   @relation(fields: [grnId], references: [id])
  supplierInvoiceId   String
  supplierInvoice     SupplierInvoice     @relation(fields: [supplierInvoiceId], references: [id])
  status              ThreeWayMatchStatus @default(PENDING)
  poTotal             Decimal             @db.Decimal(14, 2)
  grnTotal            Decimal             @db.Decimal(14, 2)
  invoiceTotal        Decimal             @db.Decimal(14, 2)
  priceVariancePct    Decimal?            @db.Decimal(8, 4)
  quantityVariancePct Decimal?            @db.Decimal(8, 4)
  tolerancePct        Decimal             @default(1) @db.Decimal(5, 2)
  discrepancyNotes    String?             @db.Text
  matchedAt           DateTime?
  matchedBy           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  paymentVouchers PaymentVoucher[]

  @@index([matchNumber])
  @@index([status])
}

model PaymentVoucher {
  id                String               @id @default(cuid())
  voucherNumber     String               @unique
  threeWayMatchId   String
  threeWayMatch     ThreeWayMatch        @relation(fields: [threeWayMatchId], references: [id])
  supplierInvoiceId String
  supplierInvoice   SupplierInvoice      @relation(fields: [supplierInvoiceId], references: [id])
  amount            Decimal              @db.Decimal(14, 2)
  currency          CurrencyCode         @default(KES)
  status            PaymentVoucherStatus @default(DRAFT)
  approvedBy        String?
  approvedAt        DateTime?
  paidAt            DateTime?
  apQueuePushedAt   DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([voucherNumber])
  @@index([status])
}

model DomainEvent {
  id            String            @id @default(cuid())
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        DomainEventStatus @default(PENDING)
  publishedAt   DateTime?
  retryCount    Int               @default(0)
  lastError     String?           @db.Text
  createdAt     DateTime          @default(now())

  @@index([status, createdAt])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
}

model ProcurementAuditLog {
  id          String                 @id @default(cuid())
  entityType  String
  entityId    String
  action      ProcurementAuditAction
  actorId     String?
  actorName   String?
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  createdAt   DateTime               @default(now())

  supplierId String?
  supplier   Supplier? @relation("SupplierAudit", fields: [supplierId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([supplierId])
}