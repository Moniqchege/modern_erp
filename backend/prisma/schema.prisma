generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  QC_INSPECTOR
  WAREHOUSE_OPERATOR
  PROCUREMENT_OFFICER
  FINANCE_DIRECTOR
  LAB_TECHNICIAN
  WEIGHBRIDGE_OPERATOR
}

enum ItemType {
  RAW_MATERIAL
  FINISHED_GOOD
  BY_PRODUCT
}

enum UnitOfMeasure {
  KG
  BAG
  TONNE
}

enum QCStatus {
  QUARANTINED
  APPROVED
  REJECTED
}

enum BatchStatus {
  QUARANTINED
  APPROVED
  REJECTED
  IN_PRODUCTION
  CONSUMED
}

enum DispatchStatus {
  PENDING
  LOADED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String
  role  UserRole @default(EMPLOYEE)

  passwordHash       String?
  forcePasswordReset Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[] @relation("InvoiceCreatedBy")
}

model OtpCode {
  id         String    @id @default(cuid())
  userId     String    @unique
  code       String
  expiresAt  DateTime
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InventoryMovementType {
  RECEIPT
  ISSUE_TO_PRODUCTION
  ISSUE_TO_PACKAGING
  SALES_DISPATCH
  ADJUSTMENT
}

model InventoryPriceHistory {
  id     String        @id @default(cuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  unitPrice     Decimal  @db.Decimal(10, 2)
  effectiveDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([itemId, effectiveDate])
}

model InventoryItem {
  id          String        @id @default(cuid())
  sku         String        @unique // UNIQUE IDENTIFIER (no duplicates)
  name        String
  description String?
  type        ItemType      @default(FINISHED_GOOD)
  unit        UnitOfMeasure @default(KG)

  // Current on-hand quantity derived from movements (still stored for fast reads)
  quantity Decimal @default(0.00) @db.Decimal(12, 3)
  productionBatchOutputs ProductionBatchOutput[]

  // Optional per-SKU reorder alert threshold (KG or BAG per unit)
  reorderLevel    Decimal? @db.Decimal(12, 3)
  reorderQuantity Decimal? @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory InventoryPriceHistory[]
  movements    InventoryMovement[]
}

model InventoryMovement {
  id     String        @id @default(cuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  movementType     InventoryMovementType
  quantityDelta    Decimal               @db.Decimal(12, 3) // positive/negative delta
  unitPriceApplied Decimal               @db.Decimal(10, 2) // stored for MVP costing trace
  movementAt       DateTime              @default(now())

  supplierId      String?
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  grnLineId       String?
  grnLine         GoodsReceivedNoteLine? @relation(fields: [grnLineId], references: [id])
  productionRunId String?
  packagingRunId  String?
  packagingRun    PackagingRun?          @relation(fields: [packagingRunId], references: [id])
  dispatchLogId   String?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, movementAt])
  @@index([movementType, movementAt])
}

// ============================================
// TRACEABILITY MODULE - SUPPLIERS & RAW MATERIALS
// ============================================

model Supplier {
  id             String  @id @default(cuid())
  code           String  @unique // e.g. SUP-001
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String? @db.Text
  farmLocation   String?
  certifications String? @db.Text

  // CRM & compliance
  businessRegistrationNo String?
  taxPin                 String?
  vatNumber              String?
  bankName               String?
  bankAccountNo          String?
  bankBranch             String?
  bankSwiftCode          String?
  onboardingStatus       SupplierOnboardingStatus @default(DRAFT)
  onboardingNotes        String?                  @db.Text
  qaApprovedAt           DateTime?
  financeApprovedAt      DateTime?
  activatedAt            DateTime?

  // Locking (maker/checker 1:1): only allow locking when onboarding is approved (onboardingStatus = ACTIVE)
  lockedAt DateTime?
  lockedBy String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  rawMaizeBatches      RawMaizeBatch[]
  complianceDocuments  SupplierComplianceDocument[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  supplierInvoices     SupplierInvoice[]
  inventoryMovements   InventoryMovement[]
  onboardingAuditLogs  ProcurementAuditLog[]        @relation("SupplierAudit")

  @@index([code])
  @@index([name])
  @@index([onboardingStatus])
  @@index([taxPin])
}

model RawMaizeBatch {
  id          String @id @default(cuid())
  batchNumber String @unique // e.g. RMB-2024-001

  // Supplier & Origin Traceability
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  farmOrigin  String? // Specific farm/field identifier
  harvestDate DateTime?

  // Truck & Weighbridge Data
  truckRegistration String // License plate
  driverName        String?
  driverPhone       String?

  grossWeight Decimal @db.Decimal(12, 3) // KG - truck + grain
  tareWeight  Decimal @db.Decimal(12, 3) // KG - empty truck
  netWeight   Decimal @db.Decimal(12, 3) // KG - actual grain weight

  // Inventory Status
  status          BatchStatus @default(QUARANTINED)
  currentQuantity Decimal     @db.Decimal(12, 3) // Remaining quantity

  // Storage Location
  siloId String?
  silo   Silo?   @relation(fields: [siloId], references: [id])

  // Timestamps
  receivedAt DateTime  @default(now())
  approvedAt DateTime?
  expiryDate DateTime? // For FIFO enforcement

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderId String?

  qualityControlLogs   QualityControlLog[]
  productionInputs     ProductionRunInput[]
  weighbridgeTickets   WeighbridgeTicket[]
  procurementQcResults ProcurementQCLabResult[]

  @@index([batchNumber])
  @@index([supplierId])
  @@index([status])
  @@index([receivedAt])
  @@index([expiryDate])
}

model QualityControlLog {
  id String @id @default(cuid())

  // Link to Raw Batch
  rawMaizeBatchId String
  rawMaizeBatch   RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id], onDelete: Cascade)

  // QC Test Results
  moistureContent Decimal  @db.Decimal(5, 2) // % (e.g., 13.50%)
  aflatoxinLevel  Decimal  @db.Decimal(8, 2) // ppb (parts per billion)
  foreignMatter   Decimal  @db.Decimal(5, 2) // % (e.g., 0.50%)
  brokenKernels   Decimal? @db.Decimal(5, 2) // % optional

  // Test Metadata
  status   QCStatus @default(QUARANTINED)
  testedBy String // Inspector name or ID
  testDate DateTime @default(now())
  remarks  String?  @db.Text

  // Compliance Thresholds (for reference)
  // Moisture: < 14% (Approved), >= 14% (Rejected)
  // Aflatoxin: < 10 ppb (Approved), >= 10 ppb (Rejected)
  // Foreign Matter: < 2% (Approved), >= 2% (Rejected)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rawMaizeBatchId])
  @@index([status])
  @@index([testDate])
}

model Silo {
  id         String @id @default(cuid())
  siloNumber String @unique // e.g. SILO-A1
  location   String // Physical location in warehouse

  maxCapacity  Decimal @db.Decimal(12, 3) // KG
  currentLevel Decimal @default(0.00) @db.Decimal(12, 3) // KG

  isActive      Boolean   @default(true)
  lastCleanedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  rawMaizeBatches RawMaizeBatch[]
  cleaningLogs    SiloCleaningLog[]

  @@index([siloNumber])
}

model SiloCleaningLog {
  id String @id @default(cuid())

  siloId String
  silo   Silo   @relation(fields: [siloId], references: [id], onDelete: Cascade)

  cleanedBy    String // Operator name or ID
  cleaningDate DateTime @default(now())
  remarks      String?  @db.Text

  createdAt DateTime @default(now())

  @@index([siloId])
  @@index([cleaningDate])
}

// ============================================
// PRODUCTION & MILLING TRACEABILITY
// ============================================

model ProductionRun {
  id        String @id @default(cuid())
  runNumber String @unique // e.g. PR-2024-001

  // Production Line
  millingLine  String // e.g. "Line A", "Line B"
  operatorName String

  // Mass Balance Tracking
  totalRawInput        Decimal @db.Decimal(12, 3) // KG - sum of all inputs
  totalFlourOutput     Decimal @db.Decimal(12, 3) // KG - Grade 1 + Grade 2
  totalByProductOutput Decimal @db.Decimal(12, 3) // KG - Bran + Germ
  moistureLoss         Decimal @db.Decimal(12, 3) // KG - expected moisture loss
  variance             Decimal @db.Decimal(12, 3) // KG - unaccounted difference
  variancePercent      Decimal @db.Decimal(5, 2) // % - variance as percentage

  yieldEfficiency Decimal @db.Decimal(5, 2) // % - (output / input) * 100

  // Alert Flag
  varianceAlert Boolean @default(false) // True if variance > 3%

  // Timestamps
  startTime DateTime
  endTime   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - Traceability Links
  inputs        ProductionRunInput[]
  finishedGoods FinishedGoodsBatch[]
  byProducts    ByProductBatch[]

  @@index([runNumber])
  @@index([startTime])
  @@index([varianceAlert])
}

model ProductionRunInput {
  id String @id @default(cuid())

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  rawMaizeBatchId String
  rawMaizeBatch   RawMaizeBatch @relation(fields: [rawMaizeBatchId], references: [id])

  quantityUsed Decimal @db.Decimal(12, 3) // KG consumed from this batch

  createdAt DateTime @default(now())

  @@index([productionRunId])
  @@index([rawMaizeBatchId])
}

model ByProductBatch {
  id          String @id @default(cuid())
  batchNumber String @unique // e.g. BP-2024-001

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id])

  productType     String // "MAIZE_BRAN", "MAIZE_GERM", "MIXED"
  quantity        Decimal @db.Decimal(12, 3) // KG
  currentQuantity Decimal @db.Decimal(12, 3) // Remaining after sales

  unitPrice Decimal @default(0.00) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchNumber])
  @@index([productionRunId])
}

// ============================================
// FINISHED GOODS - HIERARCHICAL TRACEABILITY
// ============================================

model FinishedGoodsBatch {
  id          String @id @default(cuid())
  batchNumber String @unique // e.g. FG-2024-001

  productionRunId String
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id])

  productType     String // "GRADE_1_FLOUR", "GRADE_2_FLOUR"
  totalQuantity   Decimal @db.Decimal(12, 3) // KG - total produced
  currentQuantity Decimal @db.Decimal(12, 3) // KG - remaining in stock

  packagingDate DateTime @default(now())
  expiryDate    DateTime // For FIFO enforcement

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - Hierarchical Structure
  pallets Pallet[]

  @@index([batchNumber])
  @@index([productionRunId])
  @@index([expiryDate])
}

model Pallet {
  id            String @id @default(cuid())
  palletBarcode String @unique // Scannable barcode

  finishedGoodsBatchId String
  finishedGoodsBatch   FinishedGoodsBatch @relation(fields: [finishedGoodsBatchId], references: [id])

  totalWeight Decimal @db.Decimal(12, 3) // KG

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bales         Bale[]
  dispatchItems DispatchItem[]

  @@index([palletBarcode])
  @@index([finishedGoodsBatchId])
}

model Bale {
  id          String @id @default(cuid())
  baleBarcode String @unique // Scannable barcode

  palletId String
  pallet   Pallet @relation(fields: [palletId], references: [id], onDelete: Cascade)

  totalWeight Decimal @db.Decimal(12, 3) // KG

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bags Bag[]

  @@index([baleBarcode])
  @@index([palletId])
}

model Bag {
  id         String @id @default(cuid())
  bagBarcode String @unique // Scannable barcode - FINAL RETAIL UNIT

  baleId String
  bale   Bale   @relation(fields: [baleId], references: [id], onDelete: Cascade)

  weight Decimal @db.Decimal(12, 3) // KG (e.g., 2.000 KG)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bagBarcode])
  @@index([baleId])
}

// ============================================
// DISPATCH & CUSTOMER DELIVERY TRACEABILITY
// ============================================

model DispatchLog {
  id             String @id @default(cuid())
  dispatchNumber String @unique // e.g. DISP-2024-001

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Optional linkage to sales invoice for strict forward trace.
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  truckRegistration String
  driverName        String
  driverPhone       String?

  status DispatchStatus @default(PENDING)

  loadedAt    DateTime?
  deliveredAt DateTime?

  deliveryAddress String  @db.Text
  remarks         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items DispatchItem[]

  @@index([dispatchNumber])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([loadedAt])
}

model DispatchItem {
  id String @id @default(cuid())

  dispatchLogId String
  dispatchLog   DispatchLog @relation(fields: [dispatchLogId], references: [id], onDelete: Cascade)

  palletId String
  pallet   Pallet @relation(fields: [palletId], references: [id])

  quantity Decimal @db.Decimal(12, 3) // KG

  createdAt DateTime @default(now())

  @@index([dispatchLogId])
  @@index([palletId])
}

// ============================================
// LEGACY MODELS (Updated with Relations)
// ============================================

model ProductionBatch {
  id          String @id @default(cuid())
  batchNumber String @unique

  rawMaizeConsumed Decimal @db.Decimal(12, 3)
  wasteLoss        Decimal @db.Decimal(12, 3)
  efficiency       Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outputs ProductionBatchOutput[]

  @@index([batchNumber])
}

model ProductionBatchOutput {
  id                String @id @default(cuid())
  productionBatchId String
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)

  inventoryItemId   String
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantityKg        Decimal @db.Decimal(12, 3)

  @@index([productionBatchId])
}

// ============================================
// PACKAGING — bulk flour to 24kg bales
// ============================================

model PackagingRun {
  id        String @id @default(cuid())
  runNumber String @unique

  operatorName String
  baleWeightKg Decimal @default(24) @db.Decimal(12, 3)

  flourSpillage       Decimal @default(0) @db.Decimal(12, 3)

  packagingMaterialReceived  Decimal @default(0) @db.Decimal(12, 3)
  packagingMaterialConsumed  Decimal @default(0) @db.Decimal(12, 3)
  packagingMaterialDestroyed Decimal @default(0) @db.Decimal(12, 3)

  totalPackagedKg     Decimal @db.Decimal(12, 3)
  yieldPercent        Decimal @db.Decimal(5, 2)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  movements InventoryMovement[]
  finishedProductInputs PackagingRunFinishedProductInput[]
  finishedProductOutputs PackagingRunFinishedProductOutput[]

  @@index([runNumber])
  @@index([createdAt])
}

// ============================================
// PACKAGING — normalized per-finished-product breakdown
// ============================================

model PackagingRunFinishedProductInput {
  id String @id @default(cuid())

  packagingRunId String
  packagingRun   PackagingRun @relation(fields: [packagingRunId], references: [id], onDelete: Cascade)

  // Human/configurable finished product name
  finishedProductName String @db.VarChar(255)

  // Flour input (kg)
  flourConsumedKg Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packagingRunId])
  @@index([finishedProductName])
}

model PackagingRunFinishedProductOutput {
  id String @id @default(cuid())

  packagingRunId String
  packagingRun   PackagingRun @relation(fields: [packagingRunId], references: [id], onDelete: Cascade)

  finishedProductName String @db.VarChar(255)

  // Bale output count and packaged weight
  balesProduced Int
  packagedKg    Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packagingRunId])
  @@index([finishedProductName])
}


model Customer {
  id      String  @id @default(cuid())
  name    String
  email   String? @unique
  phone   String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices   Invoice[]
  dispatches DispatchLog[]
}

model Invoice {
  id String @id @default(cuid())

  invoiceNumber String @unique

  // Relations
  dispatches DispatchLog[]

  // Money fields
  subtotal Decimal @db.Decimal(10, 2)
  tax      Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  status   String    @default("DRAFT") // DRAFT, ISSUED, PAID, VOID
  issuedAt DateTime?

  // Relations
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PROCUREMENT & SUPPLIER MANAGEMENT MODULE
// ============================================

enum SupplierOnboardingStatus {
  DRAFT
  QA_AUDIT
  FINANCE_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ComplianceDocumentStatus {
  ACTIVE
  EXPIRING_SOON
  NON_COMPLIANT
}

enum ComplianceDocumentType {
  FOOD_SAFETY
  KEBS_CERTIFICATE
  ISO
  ORGANIC
  GLOBALGAP
  TAX_COMPLIANCE
  OTHER
}

enum ProcurementCategory {
  RAW_MATERIAL
  PACKAGING
  MILLING_CONSUMABLE
  ENGINEERING_SPARE
}

enum RawMaizeGrade {
  GRADE_A
  GRADE_B
  GRADE_C
  REJECT
}

enum PackagingBagSize {
  KG_1
  KG_2
  KG_5
  KG_10
  KG_24
  KG_50
}

enum RequisitionSource {
  LOW_STOCK_AUTO
  MANUAL_PLANT
  MANUAL_PROCUREMENT
}

enum RequisitionStatus {
  DRAFT
  PENDING_HEAD_PROCUREMENT
  PENDING_FINANCE
  APPROVED
  REJECTED
  CONVERTED_TO_PO
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
  CANCELLED
}

enum CurrencyCode {
  KES
  USD
  EUR
  UGX
  TZS
}

enum WeighbridgeDirection {
  INBOUND
  OUTBOUND
}

enum ProcurementQCStatus {
  PENDING
  PASSED
  FAILED_CONDITIONAL
  FULL_REJECTION
}

enum GrnStatus {
  DRAFT
  PENDING_QC
  POSTED
  REJECTED
  CANCELLED
}

enum ThreeWayMatchStatus {
  PENDING
  MATCHED
  PRICE_DISCREPANCY
  QUANTITY_DISCREPANCY
  BOTH_DISCREPANCY
  APPROVED_FOR_PAYMENT
  REJECTED
}

enum PaymentVoucherStatus {
  DRAFT
  APPROVED
  PAID
  VOID
}

enum DomainEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum ProcurementAuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  APPROVE
  REJECT
  POST
  VOID
}

model SupplierComplianceDocument {
  id           String                   @id @default(cuid())
  supplierId   String
  supplier     Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  documentType ComplianceDocumentType
  title        String
  fileUrl      String?                  @db.Text
  referenceNo  String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  status       ComplianceDocumentStatus @default(ACTIVE)
  notes        String?                  @db.Text
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([supplierId])
  @@index([expiresAt])
  @@index([status])
}

model ProcurementItemProfile {
  id                 String              @id @default(cuid())
  inventoryItemId    String?             @unique
  sku                String              @unique
  name               String
  category           ProcurementCategory
  unit               UnitOfMeasure       @default(KG)
  description        String?             @db.Text
  lowStockThreshold  Decimal?            @db.Decimal(12, 3)
  reorderQuantity    Decimal?            @db.Decimal(12, 3)
  rawMaizeGrade      RawMaizeGrade?
  packagingBagSize   PackagingBagSize?
  brandingDesignCode String?
  moistureMaxPct     Decimal?            @db.Decimal(5, 2)
  aflatoxinMaxPpb    Decimal?            @db.Decimal(8, 2)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  requisitionLines PurchaseRequisitionLine[]
  poLines          PurchaseOrderLine[]

  @@index([category])
  @@index([sku])
}

model ApprovalThreshold {
  id                 String       @id @default(cuid())
  name               String
  currency           CurrencyCode @default(KES)
  headProcurementMax Decimal      @db.Decimal(14, 2)
  financeDirectorMin Decimal      @db.Decimal(14, 2)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PurchaseRequisition {
  id              String            @id @default(cuid())
  requisitionNo   String            @unique
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  requestedBy     String
  department      String?
  source          RequisitionSource @default(MANUAL_PROCUREMENT)
  status          RequisitionStatus @default(DRAFT)
  justification   String?           @db.Text
  requiredByDate  DateTime?
  estimatedTotal  Decimal           @default(0) @db.Decimal(14, 2)
  currency        CurrencyCode      @default(KES)
  rejectionReason String?           @db.Text
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  lines          PurchaseRequisitionLine[]
  approvals      ProcurementApproval[]
  purchaseOrders PurchaseOrder[]

  @@index([requisitionNo])
  @@index([status])
  @@index([supplierId])
}

model PurchaseRequisitionLine {
  id                String                 @id @default(cuid())
  requisitionId     String
  requisition       PurchaseRequisition    @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemProfileId     String
  itemProfile       ProcurementItemProfile @relation(fields: [itemProfileId], references: [id])
  quantity          Decimal                @db.Decimal(12, 3)
  unitPriceEstimate Decimal?               @db.Decimal(12, 2)
  lineTotalEstimate Decimal?               @db.Decimal(14, 2)
  notes             String?                @db.Text
  createdAt         DateTime               @default(now())

  @@index([requisitionId])
}

model ProcurementApproval {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  level        String
  approverId   String?
  approverName String
  decision     String
  comments     String?  @db.Text
  decidedAt    DateTime @default(now())

  requisitionId   String?
  requisition     PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([requisitionId])
  @@index([purchaseOrderId])
}

model PurchaseOrder {
  id                 String               @id @default(cuid())
  poNumber           String               @unique
  supplierId         String
  supplier           Supplier             @relation(fields: [supplierId], references: [id])
  requisitionId      String?
  requisition        PurchaseRequisition? @relation(fields: [requisitionId], references: [id])
  status             PurchaseOrderStatus  @default(DRAFT)
  currency           CurrencyCode         @default(KES)
  exchangeRate       Decimal              @default(1) @db.Decimal(12, 6)
  subtotal           Decimal              @default(0) @db.Decimal(14, 2)
  taxRate            Decimal              @default(16) @db.Decimal(5, 2)
  taxAmount          Decimal              @default(0) @db.Decimal(14, 2)
  totalAmount        Decimal              @default(0) @db.Decimal(14, 2)
  termsAndConditions String?              @db.Text
  expectedDelivery   DateTime?
  issuedAt           DateTime?
  issuedBy           String?
  pdfUrl             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  lines              PurchaseOrderLine[]
  weighbridgeTickets WeighbridgeTicket[]
  grns               GoodsReceivedNote[]
  supplierInvoices   SupplierInvoice[]
  approvals          ProcurementApproval[]

  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderLine {
  id               String                 @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemProfileId    String
  itemProfile      ProcurementItemProfile @relation(fields: [itemProfileId], references: [id])
  description      String?
  quantity         Decimal                @db.Decimal(12, 3)
  unitPrice        Decimal                @db.Decimal(12, 2)
  taxAmount        Decimal                @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal                @db.Decimal(14, 2)
  quantityReceived Decimal                @default(0) @db.Decimal(12, 3)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  grnLines GoodsReceivedNoteLine[]

  @@index([purchaseOrderId])
}

model WeighbridgeTicket {
  id                String               @id @default(cuid())
  ticketNumber      String               @unique
  direction         WeighbridgeDirection @default(INBOUND)
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  rawMaizeBatchId   String?
  rawMaizeBatch     RawMaizeBatch?       @relation(fields: [rawMaizeBatchId], references: [id])
  truckRegistration String
  driverName        String?
  grossWeightKg     Decimal              @db.Decimal(12, 3)
  tareWeightKg      Decimal              @db.Decimal(12, 3)
  netWeightKg       Decimal              @db.Decimal(12, 3)
  weighedInAt       DateTime             @default(now())
  weighedOutAt      DateTime?
  operatorName      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  grns      GoodsReceivedNote[]
  qcResults ProcurementQCLabResult[]

  @@index([ticketNumber])
  @@index([purchaseOrderId])
}

model ProcurementQCLabResult {
  id                   String              @id @default(cuid())
  qcNumber             String              @unique
  category             ProcurementCategory
  weighbridgeTicketId  String?
  weighbridgeTicket    WeighbridgeTicket?  @relation(fields: [weighbridgeTicketId], references: [id])
  rawMaizeBatchId      String?
  rawMaizeBatch        RawMaizeBatch?      @relation(fields: [rawMaizeBatchId], references: [id])
  grnId                String?
  grn                  GoodsReceivedNote?  @relation(fields: [grnId], references: [id])
  status               ProcurementQCStatus @default(PENDING)
  testedBy             String
  testedAt             DateTime            @default(now())
  moistureContentPct   Decimal?            @db.Decimal(5, 2)
  aflatoxinPpb         Decimal?            @db.Decimal(8, 2)
  rottenBrokenPct      Decimal?            @db.Decimal(5, 2)
  foreignMatterPct     Decimal?            @db.Decimal(5, 2)
  liveInsectsCount     Int?
  assignedGrade        RawMaizeGrade?
  tensileStrengthN     Decimal?            @db.Decimal(10, 2)
  printAlignmentScore  Decimal?            @db.Decimal(5, 2)
  dimensionAccuracyMm  Decimal?            @db.Decimal(8, 2)
  priceDeductionPct    Decimal?            @db.Decimal(5, 2)
  priceDeductionAmount Decimal?            @db.Decimal(14, 2)
  acceptedQuantity     Decimal?            @db.Decimal(12, 3)
  rejectionNote        String?             @db.Text
  remarks              String?             @db.Text
  blocksInventoryPost  Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([qcNumber])
  @@index([status])
  @@index([rawMaizeBatchId])
}

model GoodsReceivedNote {
  id                  String             @id @default(cuid())
  grnNumber           String             @unique
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  weighbridgeTicketId String?
  weighbridgeTicket   WeighbridgeTicket? @relation(fields: [weighbridgeTicketId], references: [id])
  deliverySequence    Int                @default(1)
  status              GrnStatus          @default(PENDING_QC)
  receivedAt          DateTime           @default(now())
  receivedBy          String
  lotNumber           String?
  batchTraceCode      String?
  netWeightAccepted   Decimal?           @db.Decimal(12, 3)
  postedAt            DateTime?
  postedBy            String?
  notes               String?            @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  lines           GoodsReceivedNoteLine[]
  qcResults       ProcurementQCLabResult[]
  threeWayMatches ThreeWayMatch[]

  @@index([grnNumber])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([lotNumber])
  @@index([batchTraceCode])
}

model GoodsReceivedNoteLine {
  id                  String            @id @default(cuid())
  grnId               String
  grn                 GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  quantityAccepted    Decimal           @db.Decimal(12, 3)
  quantityRejected    Decimal           @default(0) @db.Decimal(12, 3)
  unitPriceApplied    Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(14, 2)
  lotNumber           String?
  createdAt           DateTime          @default(now())

  inventoryMovements InventoryMovement[]

  @@index([grnId])
  @@index([purchaseOrderLineId])
}

model SupplierInvoice {
  id              String        @id @default(cuid())
  invoiceNumber   String
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  invoiceDate     DateTime
  dueDate         DateTime?
  currency        CurrencyCode  @default(KES)
  subtotal        Decimal       @db.Decimal(14, 2)
  taxAmount       Decimal       @db.Decimal(14, 2)
  totalAmount     Decimal       @db.Decimal(14, 2)
  fileUrl         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  threeWayMatches ThreeWayMatch[]
  paymentVouchers PaymentVoucher[]

  @@unique([supplierId, invoiceNumber])
  @@index([purchaseOrderId])
}

model ThreeWayMatch {
  id                  String              @id @default(cuid())
  matchNumber         String              @unique
  purchaseOrderId     String
  grnId               String
  grn                 GoodsReceivedNote   @relation(fields: [grnId], references: [id])
  supplierInvoiceId   String
  supplierInvoice     SupplierInvoice     @relation(fields: [supplierInvoiceId], references: [id])
  status              ThreeWayMatchStatus @default(PENDING)
  poTotal             Decimal             @db.Decimal(14, 2)
  grnTotal            Decimal             @db.Decimal(14, 2)
  invoiceTotal        Decimal             @db.Decimal(14, 2)
  priceVariancePct    Decimal?            @db.Decimal(8, 4)
  quantityVariancePct Decimal?            @db.Decimal(8, 4)
  tolerancePct        Decimal             @default(1) @db.Decimal(5, 2)
  discrepancyNotes    String?             @db.Text
  matchedAt           DateTime?
  matchedBy           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  paymentVouchers PaymentVoucher[]

  @@index([matchNumber])
  @@index([status])
}

model PaymentVoucher {
  id                String               @id @default(cuid())
  voucherNumber     String               @unique
  threeWayMatchId   String
  threeWayMatch     ThreeWayMatch        @relation(fields: [threeWayMatchId], references: [id])
  supplierInvoiceId String
  supplierInvoice   SupplierInvoice      @relation(fields: [supplierInvoiceId], references: [id])
  amount            Decimal              @db.Decimal(14, 2)
  currency          CurrencyCode         @default(KES)
  status            PaymentVoucherStatus @default(DRAFT)
  approvedBy        String?
  approvedAt        DateTime?
  paidAt            DateTime?
  apQueuePushedAt   DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([voucherNumber])
  @@index([status])
}

model DomainEvent {
  id            String            @id @default(cuid())
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        DomainEventStatus @default(PENDING)
  publishedAt   DateTime?
  retryCount    Int               @default(0)
  lastError     String?           @db.Text
  createdAt     DateTime          @default(now())

  @@index([status, createdAt])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
}

model ProcurementAuditLog {
  id          String                 @id @default(cuid())
  entityType  String
  entityId    String
  action      ProcurementAuditAction
  actorId     String?
  actorName   String?
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  createdAt   DateTime               @default(now())

  supplierId String?
  supplier   Supplier? @relation("SupplierAudit", fields: [supplierId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([supplierId])
}
